# DigitalOcean
do_token     = "dop_v1_your_token_here"
region       = "sgp1"
cluster_name = "robust2api"
k8s_version  = "1.34"
node_size    = "s-2vcpu-4gb"
min_nodes    = 1
max_nodes    = 3

# Cloudflare bootstrap secret (used by Flux-managed cert-manager and ExternalDNS)
cloudflare_api_token = "your_cloudflare_api_token_here"

# Managed PostgreSQL (optional, default false)
enable_managed_database = false
# db_size               = "db-s-1vcpu-1gb"

# Observability storage (optional, default false)
# Creates Cloudflare R2 buckets for the optional Flux-managed Tempo and Loki releases
enable_observability_storage = false
# cloudflare_account_id = "your_cloudflare_account_id"

# Optional managed PostgreSQL reader username used when you later configure Grafana dashboards
# managed_grafana_reader_user = "grafana_reader"
