{
  "title": "Robust2API Admin Overview",
  "uid": "robust2api-admin-overview",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "timezone": "browser",
  "time": { "from": "now-24h", "to": "now" },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "Total Users",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "postgres", "uid": "robust2api-pg" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT COUNT(*)::double precision AS value FROM users WHERE deleted_at IS NULL"
        }
      ]
    },
    {
      "id": 2,
      "title": "Active API Keys",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "postgres", "uid": "robust2api-pg" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT COUNT(*)::double precision AS value FROM api_keys WHERE deleted_at IS NULL AND status = 'active'"
        }
      ]
    },
    {
      "id": 3,
      "title": "Total Accounts",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "postgres", "uid": "robust2api-pg" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT COUNT(*)::double precision AS value FROM accounts WHERE deleted_at IS NULL"
        }
      ]
    },
    {
      "id": 4,
      "title": "Today Requests",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "postgres", "uid": "robust2api-pg" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT COALESCE(total_requests, 0)::double precision AS value FROM usage_dashboard_daily WHERE bucket_date = CURRENT_DATE"
        }
      ]
    },
    {
      "id": 5,
      "title": "Total Requests",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "postgres", "uid": "robust2api-pg" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT COALESCE(SUM(total_requests), 0)::double precision AS value FROM usage_dashboard_daily"
        }
      ]
    },
    {
      "id": 6,
      "title": "Today Actual Cost",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "postgres", "uid": "robust2api-pg" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT COALESCE(actual_cost, 0)::double precision AS value FROM usage_dashboard_daily WHERE bucket_date = CURRENT_DATE"
        }
      ]
    },
    {
      "id": 7,
      "title": "Today Tokens",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 4 },
      "datasource": { "type": "postgres", "uid": "robust2api-pg" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT COALESCE(input_tokens + output_tokens + cache_creation_tokens + cache_read_tokens, 0)::double precision AS value FROM usage_dashboard_daily WHERE bucket_date = CURRENT_DATE"
        }
      ]
    },
    {
      "id": 8,
      "title": "Total Tokens",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 4 },
      "datasource": { "type": "postgres", "uid": "robust2api-pg" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT COALESCE(SUM(input_tokens + output_tokens + cache_creation_tokens + cache_read_tokens), 0)::double precision AS value FROM usage_dashboard_daily"
        }
      ]
    },
    {
      "id": 9,
      "title": "Total Actual Cost",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 4 },
      "datasource": { "type": "postgres", "uid": "robust2api-pg" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT COALESCE(SUM(actual_cost), 0)::double precision AS value FROM usage_dashboard_daily"
        }
      ]
    },
    {
      "id": 10,
      "title": "Active Users (Today)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 4 },
      "datasource": { "type": "postgres", "uid": "robust2api-pg" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT COALESCE(active_users, 0)::double precision AS value FROM usage_dashboard_daily WHERE bucket_date = CURRENT_DATE"
        }
      ]
    },
    {
      "id": 11,
      "title": "RPM (Last Hour)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 4 },
      "datasource": { "type": "postgres", "uid": "robust2api-pg" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT COALESCE(total_requests / 60.0, 0)::double precision AS value FROM usage_dashboard_hourly ORDER BY bucket_start DESC LIMIT 1"
        }
      ]
    },
    {
      "id": 12,
      "title": "Average Duration (ms)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 4 },
      "datasource": { "type": "postgres", "uid": "robust2api-pg" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT CASE WHEN COALESCE(SUM(total_requests), 0) = 0 THEN 0 ELSE (SUM(total_duration_ms)::double precision / SUM(total_requests)::double precision) END AS value FROM usage_dashboard_daily"
        }
      ]
    },
    {
      "id": 13,
      "title": "Requests Trend (Hourly)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "postgres", "uid": "robust2api-pg" },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT $__timeGroupAlias(bucket_start, '1h'), SUM(total_requests)::double precision AS requests FROM usage_dashboard_hourly WHERE $__timeFilter(bucket_start) GROUP BY 1 ORDER BY 1"
        }
      ]
    },
    {
      "id": 14,
      "title": "Actual Cost Trend (Daily)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "postgres", "uid": "robust2api-pg" },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT $__timeGroupAlias(bucket_date::timestamp, '1d'), SUM(actual_cost)::double precision AS actual_cost FROM usage_dashboard_daily WHERE $__timeFilter(bucket_date::timestamp) GROUP BY 1 ORDER BY 1"
        }
      ]
    }
  ]
}
